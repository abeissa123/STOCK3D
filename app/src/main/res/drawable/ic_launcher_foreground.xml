<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 3D Isometric Cube / Cargo Box inside the 66dp safe zone (centered around 54, 54) -->
    <!-- Top Face of the Cube -->
    <path android:pathData="M54,28 L76,39 L54,50 L32,39 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="32"
                android:startY="39"
                android:endX="76"
                android:endY="39">
                <item android:offset="0.0" android:color="#00F0FF" />
                <item android:offset="1.0" android:color="#00A2FF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Right Face of the Cube (shaded) -->
    <path android:pathData="M54,50 L76,39 V66 L54,77 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54"
                android:startY="58"
                android:endX="76"
                android:endY="58">
                <item android:offset="0.0" android:color="#0066CC" />
                <item android:offset="1.0" android:color="#003399" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Left Face of the Cube (semi-shaded) -->
    <path android:pathData="M32,39 L54,50 V77 L32,66 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="32"
                android:startY="58"
                android:endX="54"
                android:endY="58">
                <item android:offset="0.0" android:color="#0099FF" />
                <item android:offset="1.0" android:color="#0055CC" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Arrow icon on the top face indicating "In/Out" Stock Flow -->
    <path
        android:pathData="M54,33 L60,37 M54,33 L48,37 M54,33 V43"
        android:strokeWidth="2.5"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <!-- Neon Barcode Scanning Slicing Laser Beam (Horizontal line) -->
    <path
        android:pathData="M22,54 H86"
        android:strokeWidth="3.5"
        android:strokeColor="#FF6B00"
        android:strokeLineCap="round" />

    <path
        android:pathData="M22,54 H86"
        android:strokeWidth="1.5"
        android:strokeColor="#FFC800"
        android:strokeLineCap="round" />

    <!-- Barcode simulation background behind the cube (subtle neon lines) -->
    <path
        android:pathData="M34,20 V26 M38,20 V26 M44,20 V26 M48,20 V26 M56,20 V26 M62,20 V26 M68,20 V26"
        android:strokeWidth="1"
        android:strokeColor="#00F0FF" />
</vector>
